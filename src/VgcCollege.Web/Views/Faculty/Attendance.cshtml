@model VgcCollege.Web.Models.CourseEnrolment
@{ ViewData["Title"] = "Attendance"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check me-2 text-warning"></i>Attendance – @Model.StudentProfile.Name</h2>
    <a asp-action="CourseStudents" asp-route-courseId="@Model.CourseId" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <strong>@Model.Course.Name</strong> &mdash; Enrolled @Model.EnrolDate.ToString("dd MMM yyyy")
    </div>
    <div class="card-body p-0">
        @if (!Model.AttendanceRecords.Any())
        {
            <p class="text-muted p-3 mb-0">No attendance recorded yet.</p>
        }
        else
        {
            <table class="table mb-0">
                <thead class="table-dark">
                    <tr><th>Week</th><th>Date</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var ar in Model.AttendanceRecords)
                {
                    <tr>
                        <td>Week @ar.WeekNumber</td>
                        <td>@ar.SessionDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (ar.Present)
                            { <span class="badge bg-success"><i class="bi bi-check me-1"></i>Present</span> }
                            else
                            { <span class="badge bg-danger"><i class="bi bi-x me-1"></i>Absent</span> }
                        </td>
                        <td>
                            <!-- Delete button so faculty can correct mistakes -->
                            <form asp-action="DeleteAttendance" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this attendance record?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ar.Id" />
                                <input type="hidden" name="enrolmentId" value="@Model.Id" />
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Add / update attendance record -->
<div class="card shadow-sm" style="max-width:500px">
    <div class="card-header fw-semibold">
        <i class="bi bi-plus me-2"></i>Record / Update Attendance
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Submitting an existing week number will <strong>overwrite</strong> that record.
        </p>
        <form asp-action="AddAttendance" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="enrolmentId" value="@Model.Id" />
            <div class="row g-2 mb-3">
                <div class="col">
                    <label class="form-label fw-semibold">Week #</label>
                    <input name="weekNumber" type="number" min="1" max="52" class="form-control" required />
                </div>
                <div class="col">
                    <label class="form-label fw-semibold">Session Date</label>
                    <input name="sessionDate" type="date" class="form-control"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
            </div>
            <div class="mb-3 form-check">
                <input name="present" type="checkbox" class="form-check-input" id="presentCheck"
                       value="true" checked />
                <label class="form-check-label" for="presentCheck">Mark as Present</label>
            </div>
            <button type="submit" class="btn btn-dark">
                <i class="bi bi-save me-1"></i>Save
            </button>
        </form>
    </div>
</div>
