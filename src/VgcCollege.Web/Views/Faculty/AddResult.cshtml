@model VgcCollege.Web.Models.AssignmentResult
@{ ViewData["Title"] = "Add Result"; }

<h2 class="mb-4"><i class="bi bi-plus me-2"></i>Add Assignment Result</h2>
<div class="card shadow-sm" style="max-width:540px">
    <div class="card-body">
        <form asp-action="AddResult" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label fw-semibold">Assignment</label>
                <select asp-for="AssignmentId" asp-items="ViewBag.AssignmentId" class="form-select">
                    <option value="">-- Select assignment --</option>
                </select>
                <span asp-validation-for="AssignmentId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label fw-semibold">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.StudentProfileId" class="form-select">
                    <option value="">-- Select student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label fw-semibold"></label>
                <input asp-for="Score" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="Score" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Feedback" class="form-label fw-semibold"></label>
                <textarea asp-for="Feedback" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Gradebook" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
