@model VgcCollege.Web.Models.ExamResult
@{ ViewData["Title"] = "Add Exam Result"; }

<h2 class="mb-4"><i class="bi bi-plus me-2"></i>Add Exam Result</h2>
<div class="card shadow-sm" style="max-width:540px">
    <div class="card-body">
        <form asp-action="AddExamResult" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="ExamId" class="form-label fw-semibold">Exam</label>
                <select asp-for="ExamId" asp-items="ViewBag.ExamId" class="form-select">
                    <option value="">-- Select exam --</option>
                </select>
                <span asp-validation-for="ExamId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label fw-semibold">Student</label>
                <select asp-for="StudentProfileId" asp-items="ViewBag.StudentProfileId" class="form-select">
                    <option value="">-- Select student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label fw-semibold"></label>
                <input asp-for="Score" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="Score" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="ExamResults" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
