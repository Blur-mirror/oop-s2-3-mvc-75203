@model VgcCollege.Web.Models.Course
@{ ViewData["Title"] = "Students – " + Model.Name; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2 text-warning"></i>@Model.Name – Students</h2>
    <a asp-action="MyCourses" class="btn btn-outline-dark"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Student</th><th>Student No.</th><th>Status</th><th>Attendance</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var e in Model.Enrolments)
            {
                var attended = e.AttendanceRecords.Count(a => a.Present);
                var total    = e.AttendanceRecords.Count;
                var pct      = total > 0 ? (int)(attended * 100.0 / total) : 0;
                <tr>
                    <td>@e.StudentProfile.Name</td>
                    <td><code>@e.StudentProfile.StudentNumber</code></td>
                    <td><span class="badge @(e.Status=="Active"?"bg-success":"bg-secondary")">@e.Status</span></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress flex-grow-1" style="height:8px;">
                                <div class="progress-bar @(pct>=75?"bg-success":pct>=50?"bg-warning":"bg-danger")"
                                     style="width:@pct%"></div>
                            </div>
                            <small>@attended/@total</small>
                        </div>
                    </td>
                    <td>
                        <a asp-action="Attendance" asp-route-enrolmentId="@e.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-calendar-check me-1"></i>Attendance
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
