@model VgcCollege.Web.Models.AssignmentResult
@{ ViewData["Title"] = "Edit Result"; }

<h2 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Result</h2>
<div class="card shadow-sm" style="max-width:540px">
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-4">Assignment</dt><dd class="col-sm-8">@Model.Assignment.Title</dd>
            <dt class="col-sm-4">Student</dt><dd class="col-sm-8">@Model.StudentProfile.Name</dd>
            <dt class="col-sm-4">Max Score</dt><dd class="col-sm-8">@Model.Assignment.MaxScore</dd>
        </dl>
        <form asp-action="EditResult" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Score" class="form-label fw-semibold"></label>
                <input asp-for="Score" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="Score" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Feedback" class="form-label fw-semibold"></label>
                <textarea asp-for="Feedback" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Gradebook" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
