@model IEnumerable<VgcCollege.Web.Models.StudentProfile>
@{
    ViewData["Title"] = "Student Contacts";
}

<h2 class="mb-4"><i class="bi bi-person-lines-fill me-2 text-warning"></i>Student Contacts</h2>
<div class="alert alert-info small">
    <i class="bi bi-shield-lock me-2"></i>
    You can view contact details only for students in courses where your role is<strong>Tutor</strong>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">No students found. You may need a Tutor role assignment.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Student No.</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.Name</td>
                            <td><code>@s.StudentNumber</code></td>
                            <td><a href="mailto:@s.Email">@s.Email</a></td>
                            <td>@(s.Phone ?? "—")</td>
                            <td>@(s.Address ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
