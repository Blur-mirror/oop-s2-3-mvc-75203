@model FacultyDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4" style="font-size:20px;font-weight:700;">
    <i class="bi bi-grid-1x2 me-2" style="color:var(--color-accent);"></i>
    Welcome, @Model.FacultyProfile.Name
</h2>

<div style="display:flex;gap:16px;margin-bottom:24px;flex-wrap:wrap;">
    <div class="stat-card" style="flex:1;min-width:160px;position:relative;">
        <div class="stat-icon blue"><i class="bi bi-book"></i></div>
        <div>
            <div class="stat-value">@Model.MyCourses.Count</div>
            <div class="stat-label">My Courses</div>
        </div>
        <a asp-action="MyCourses" class="stretched-link"></a>
    </div>
    <div class="stat-card" style="flex:1;min-width:160px;position:relative;">
        <div class="stat-icon green"><i class="bi bi-people"></i></div>
        <div>
            <div class="stat-value">@Model.MyCourses.Sum(c => c.Enrolments.Count)</div>
            <div class="stat-label">My Students</div>
        </div>
        <a asp-action="MyCourses" class="stretched-link"></a>
    </div>
    <div class="stat-card" style="flex:1;min-width:160px;position:relative;">
        <div class="stat-icon gold"><i class="bi bi-table"></i></div>
        <div>
            <div class="stat-value">@Model.RecentResults.Count</div>
            <div class="stat-label">Recent Results</div>
        </div>
        <a asp-action="Gradebook" class="stretched-link"></a>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card">
        <div class="card-header"><i class="bi bi-book me-2"></i>My Courses</div>
        <ul class="list-group list-group-flush">
            @foreach (var c in Model.MyCourses)
            {
                <li class="list-group-item">
                    <div>
                        <span style="font-weight:500;">@c.Name</span>
                        <small class="text-muted ms-2">@c.Branch.Name</small>
                    </div>
                    <a asp-action="CourseStudents" asp-route-courseId="@c.Id"
                       class="btn btn-sm btn-outline-secondary">Students</a>
                </li>
            }
        </ul>
    </div>
    <div class="card">
        <div class="card-header"><i class="bi bi-clock-history me-2"></i>Recent Results</div>
        <ul class="list-group list-group-flush">
            @foreach (var r in Model.RecentResults)
            {
                <li class="list-group-item">
                    <div>
                        <span style="font-weight:500;">@r.StudentProfile.Name</span>
                        <small class="text-muted d-block">@r.Assignment.Title</small>
                    </div>
                    <span class="badge bg-primary">@r.Score / @r.Assignment.MaxScore</span>
                </li>
            }
        </ul>
    </div>
</div>
