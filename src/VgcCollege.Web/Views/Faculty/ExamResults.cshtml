@model IEnumerable<VgcCollege.Web.Models.ExamResult>
@{ ViewData["Title"] = "Exam Results"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-pencil-square me-2 text-warning"></i>Exam Results</h2>
    <a asp-action="AddExamResult" class="btn btn-dark"><i class="bi bi-plus me-1"></i>Add Result</a>
</div>

<!-- exam filter -->
<form method="get" class="filter-bar">
    <select name="examId" asp-items="ViewBag.ExamId" class="form-select">
        <option value="">All Exams</option>
    </select>
    <button type="submit" class="btn btn-outline-secondary">
        <i class="bi bi-funnel me-1"></i>Filter
    </button>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Student</th><th>Exam</th><th>Course</th><th>Score</th><th>Grade</th><th>Released?</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.StudentProfile.Name</td>
                    <td>@r.Exam.Title</td>
                    <td>@r.Exam.Course.Name</td>
                    <td>@r.Score / @r.Exam.MaxScore</td>
                    <td><span class="badge bg-primary">@r.Grade</span></td>
                    <td>
                        @if (r.Exam.ResultsReleased)
                        { <span class="badge bg-success">Released</span> }
                        else
                        { <span class="badge bg-warning text-dark">Provisional</span> }
                    </td>
                    <td>
                        <a asp-action="EditExamResult" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
