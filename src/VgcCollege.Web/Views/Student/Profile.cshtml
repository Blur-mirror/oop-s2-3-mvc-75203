@model VgcCollege.Web.Models.StudentProfile
@{ ViewData["Title"] = "My Profile"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-circle me-2 text-warning"></i>My Profile</h2>
    <a asp-action="EditProfile" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>

<div class="card shadow-sm" style="max-width:520px">
    <ul class="list-group list-group-flush">
        <li class="list-group-item"><strong>Student Number:</strong> <code>@Model.StudentNumber</code></li>
        <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
        <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
        <li class="list-group-item"><strong>Phone:</strong> @(Model.Phone ?? "—")</li>
        <li class="list-group-item"><strong>Address:</strong> @(Model.Address ?? "—")</li>
        <li class="list-group-item"><strong>Date of Birth:</strong> @Model.DateOfBirth.ToString("dd MMM yyyy")</li>
    </ul>
</div>
