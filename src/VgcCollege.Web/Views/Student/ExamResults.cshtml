@model IEnumerable<StudentExamResultViewModel>
@{ ViewData["Title"] = "Exam Results"; }

<h2 class="mb-4"><i class="bi bi-pencil-square me-2 text-warning"></i>My Exam Results</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No exam results recorded yet.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr><th>Exam</th><th>Course</th><th>Date</th><th>Score</th><th>Grade</th><th>Status</th></tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold">@r.ExamTitle</td>
                        <td>@r.CourseName</td>
                        <td>@r.ExamDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (r.IsReleased)
                            {
                                <span>@r.Score / @r.MaxScore</span>
                            }
                            else
                            {
                                <!-- Score is null server-side – never expose it -->
                                <span class="text-muted fst-italic">Not yet available</span>
                            }
                        </td>
                        <td>
                            @if (r.IsReleased && r.Grade != null)
                            { <span class="badge bg-primary fs-6">@r.Grade</span> }
                            else
                            { <span class="badge bg-secondary">—</span> }
                        </td>
                        <td>
                            @if (r.IsReleased)
                            { <span class="badge bg-success"><i class="bi bi-unlock me-1"></i>Released</span> }
                            else
                            { <span class="badge bg-warning text-dark"><i class="bi bi-lock me-1"></i>Provisional</span> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted small mt-2">
        <i class="bi bi-info-circle me-1"></i>
        Provisional results are visible to staff only. Your score will appear once your lecturer releases the results.
    </p>
}
