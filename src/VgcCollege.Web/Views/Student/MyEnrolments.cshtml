@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{ ViewData["Title"] = "My Courses"; }

<h2 class="mb-4"><i class="bi bi-journal-check me-2 text-warning"></i>My Courses</h2>

@foreach (var e in Model)
{
    var attended = e.AttendanceRecords.Count(a => a.Present);
    var total    = e.AttendanceRecords.Count;
    var pct      = total > 0 ? (int)(attended * 100.0 / total) : 0;

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@e.Course.Name</span>
            <span class="badge bg-secondary">@e.Course.Branch.Name</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-sm-6">
                    <dl class="mb-0">
                        <dt class="small text-muted">Status</dt>
                        <dd><span class="badge @(e.Status=="Active"?"bg-success":"bg-secondary")">@e.Status</span></dd>
                        <dt class="small text-muted">Enrolled</dt>
                        <dd>@e.EnrolDate.ToString("dd MMM yyyy")</dd>
                        <dt class="small text-muted">Course Period</dt>
                        <dd>@e.Course.StartDate.ToString("MMM yyyy") – @e.Course.EndDate.ToString("MMM yyyy")</dd>
                    </dl>
                </div>
                <div class="col-sm-6">
                    <p class="small text-muted mb-1">Attendance</p>
                    <div class="progress mb-1" style="height:10px;">
                        <div class="progress-bar @(pct>=75?"bg-success":pct>=50?"bg-warning":"bg-danger")"
                             style="width:@pct%" title="@pct%"></div>
                    </div>
                    <small>@attended / @total sessions (@pct%)</small>
                </div>
            </div>
        </div>
    </div>
}
