@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>
@{ ViewData["Title"] = "My Grades"; }

<h2 class="mb-4"><i class="bi bi-table me-2 text-warning"></i>My Assignment Grades</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No assignment results yet.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr><th>Assignment</th><th>Course</th><th>Due</th><th>Score</th><th>Percentage</th><th>Feedback</th></tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold">@r.Assignment.Title</td>
                        <td>@r.Assignment.Course.Name</td>
                        <td>@r.Assignment.DueDate.ToString("dd MMM yyyy")</td>
                        <td>@r.Score / @r.Assignment.MaxScore</td>
                        <td>
                            <span class="badge @(r.Percentage>=70?"bg-success":r.Percentage>=50?"bg-warning text-dark":"bg-danger")">
                                @r.Percentage%
                            </span>
                        </td>
                        <td><small class="text-muted">@(r.Feedback ?? "—")</small></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
