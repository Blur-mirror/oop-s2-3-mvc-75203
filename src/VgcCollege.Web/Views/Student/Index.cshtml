@model StudentDashboardViewModel
@{ ViewData["Title"] = "My Dashboard"; }

<h2 class="mb-1"><i class="bi bi-person-circle me-2 text-warning"></i>Welcome, @Model.Profile.Name</h2>
<p class="text-muted mb-4"><code>@Model.Profile.StudentNumber</code></p>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-primary">@Model.Profile.Enrolments.Count</div>
                <div class="text-muted small"><i class="bi bi-journal-check me-1"></i>Courses Enrolled</div>
                <a asp-action="MyEnrolments" class="stretched-link"></a>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-success">@Model.Profile.AssignmentResults.Count</div>
                <div class="text-muted small"><i class="bi bi-table me-1"></i>Assignment Results</div>
                <a asp-action="Gradebook" class="stretched-link"></a>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-info">@Model.Profile.Enrolments.SelectMany(e => e.AttendanceRecords).Count(a => a.Present)</div>
                <div class="text-muted small"><i class="bi bi-calendar-check me-1"></i>Sessions Attended</div>
                <a asp-action="MyEnrolments" class="stretched-link"></a>
            </div>
        </div>
    </div>
</div>

<!-- Course overview -->
<div class="card shadow-sm">
    <div class="card-header"><i class="bi bi-book me-2"></i>My Courses</div>
    <ul class="list-group list-group-flush">
    @foreach (var e in Model.Profile.Enrolments)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <strong>@e.Course.Name</strong>
                <small class="text-muted ms-2">@e.Course.Branch.Name</small>
            </div>
            <span class="badge @(e.Status=="Active"?"bg-success":"bg-secondary")">@e.Status</span>
        </li>
    }
    </ul>
</div>
