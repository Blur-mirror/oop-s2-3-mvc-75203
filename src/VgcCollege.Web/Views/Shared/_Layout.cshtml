<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – VGC College</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>

<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── Authenticated shell: sidebar + main area ──────────────────────── -->
        <div class="app-shell">

            <!-- Sidebar -->
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <a asp-controller="Home" asp-action="Index"
                           style="display:flex;align-items:center;gap:12px;text-decoration:none;width:100%;">
                        <div class="sidebar-brand-icon">🎓</div>
                        <div class="sidebar-brand-text">
                            <strong>VGC College</strong>
                            <small>Management System</small>
                        </div>
                    </a>
                </div>

                @* ── Admin nav ── *@
                @if (User.IsInRole("Administrator"))
                {
                    <nav class="nav-section">
                        <div class="nav-section-label">Overview</div>
                        <a class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                               asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">Organisation</div>
                        <a class="nav-item" asp-controller="Admin" asp-action="Branches">
                            <i class="bi bi-geo-alt"></i> Branches
                        </a>
                        <a class="nav-item" asp-controller="Admin" asp-action="Courses">
                            <i class="bi bi-book"></i> Courses
                        </a>
                        <a class="nav-item" asp-controller="Admin" asp-action="Faculty">
                            <i class="bi bi-person-badge"></i> Faculty
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">Students</div>
                        <a class="nav-item" asp-controller="Admin" asp-action="Students">
                            <i class="bi bi-people"></i> All Students
                        </a>
                        <a class="nav-item" asp-controller="Admin" asp-action="Enrolments">
                            <i class="bi bi-journal-check"></i> Enrolments
                        </a>
                        <a class="nav-item" asp-controller="Admin" asp-action="CreateEnrolment">
                            <i class="bi bi-person-plus"></i> Enrol Student
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">Academics</div>
                        <a class="nav-item" asp-controller="Admin" asp-action="Assignments">
                            <i class="bi bi-file-earmark-text"></i> Assignments
                        </a>
                        <a class="nav-item" asp-controller="Admin" asp-action="Exams">
                            <i class="bi bi-pencil-square"></i> Exams &amp; Release
                        </a>
                    </nav>
                }

                @* ── Faculty nav ── *@
                @if (User.IsInRole("Faculty"))
                {
                    <nav class="nav-section">
                        <div class="nav-section-label">Overview</div>
                        <a class="nav-item" asp-controller="Faculty" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">Teaching</div>
                        <a class="nav-item" asp-controller="Faculty" asp-action="MyCourses">
                            <i class="bi bi-book"></i> My Courses
                        </a>
                        <a class="nav-item" asp-controller="Faculty" asp-action="Gradebook">
                            <i class="bi bi-table"></i> Gradebook
                        </a>
                        <a class="nav-item" asp-controller="Faculty" asp-action="ExamResults">
                            <i class="bi bi-pencil-square"></i> Exam Results
                        </a>
                        <a class="nav-item" asp-controller="Faculty" asp-action="StudentContacts">
                            <i class="bi bi-person-lines-fill"></i> Student Contacts
                        </a>
                    </nav>
                }

                @* ── Student nav ── *@
                @if (User.IsInRole("Student"))
                {
                    <nav class="nav-section">
                        <div class="nav-section-label">Overview</div>
                        <a class="nav-item" asp-controller="Student" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">My Studies</div>
                        <a class="nav-item" asp-controller="Student" asp-action="MyEnrolments">
                            <i class="bi bi-journal-check"></i> My Courses
                        </a>
                        <a class="nav-item" asp-controller="Student" asp-action="Gradebook">
                            <i class="bi bi-table"></i> My Grades
                        </a>
                        <a class="nav-item" asp-controller="Student" asp-action="ExamResults">
                            <i class="bi bi-pencil-square"></i> Exam Results
                        </a>
                    </nav>
                    <nav class="nav-section">
                        <div class="nav-section-label">Account</div>
                        <a class="nav-item" asp-controller="Student" asp-action="Profile">
                            <i class="bi bi-person-circle"></i> My Profile
                        </a>
                    </nav>
                }

                <!-- Sidebar footer: user info + sign out -->
                <div class="sidebar-footer">
                    @{
                        var displayName = User.Identity?.Name ?? "User";
                        var initial = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "?";
                        var roleLabel = User.IsInRole("Administrator") ? "Administrator"
                                      : User.IsInRole("Faculty") ? "Faculty"
                                      : "Student";
                    }
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar">@initial</div>
                        <div class="sidebar-user-info">
                            <div class="sidebar-user-name">@displayName</div>
                            <div class="sidebar-user-role">@roleLabel</div>
                        </div>
                    </div>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")"
                          method="post">
                        <button type="submit" class="btn btn-outline-secondary w-100"
                                style="width:100%;justify-content:center;">
                            <i class="bi bi-box-arrow-right"></i> Sign Out
                        </button>
                    </form>
                </div>
            </aside>

            <!-- Main area -->
            <div class="main-area">
                <!-- Topbar -->
                <div class="topbar">
                    <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
                </div>

                <!-- Flash messages -->
                <div style="padding: 0 28px;">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible mt-3">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>@TempData["Success"]</span>
                            <button type="button" class="btn-close" onclick="this.parentElement.remove()">×</button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible mt-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@TempData["Error"]</span>
                            <button type="button" class="btn-close" onclick="this.parentElement.remove()">×</button>
                        </div>
                    }
                </div>

                <!-- Page content -->
                <main class="page-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <!-- ── Unauthenticated: plain centered layout for login page ─────────── -->
        <div
            style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--color-bg);">
            @RenderBody()
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
