<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – VGC College</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <!-- ── Navbar ──────────────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-mortarboard-fill me-2 text-warning"></i>VGC College
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">

                    @* ── Administrator navigation ── *@
                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-building me-1"></i>Organisation
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Branches"><i class="bi bi-geo-alt me-2"></i>Branches</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Courses"><i class="bi bi-book me-2"></i>Courses</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Faculty"><i class="bi bi-person-badge me-2"></i>Faculty</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-people me-1"></i>Students
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Students"><i class="bi bi-person-lines-fill me-2"></i>All Students</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Enrolments"><i class="bi bi-journal-check me-2"></i>Enrolments</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateEnrolment"><i class="bi bi-person-plus me-2"></i>Enrol Student</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-clipboard-data me-1"></i>Academics
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Assignments"><i class="bi bi-file-earmark-text me-2"></i>Assignments</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Exams"><i class="bi bi-pencil-square me-2"></i>Exams &amp; Release</a></li>
                            </ul>
                        </li>
                    }

                    @* ── Faculty navigation ── *@
                    @if (User.IsInRole("Faculty"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="MyCourses">
                                <i class="bi bi-book me-1"></i>My Courses
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="Gradebook">
                                <i class="bi bi-table me-1"></i>Gradebook
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="ExamResults">
                                <i class="bi bi-pencil-square me-1"></i>Exam Results
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="StudentContacts">
                                <i class="bi bi-person-lines-fill me-1"></i>Student Contacts
                            </a>
                        </li>
                    }

                    @* ── Student navigation ── *@
                    @if (User.IsInRole("Student"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="MyEnrolments">
                                <i class="bi bi-journal-check me-1"></i>My Courses
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Gradebook">
                                <i class="bi bi-table me-1"></i>Grades
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="ExamResults">
                                <i class="bi bi-pencil-square me-1"></i>Exam Results
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Profile">
                                <i class="bi bi-person-circle me-1"></i>My Profile
                            </a>
                        </li>
                    }

                </ul>

                <!-- Login / logout partial -->
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- ── Flash messages ──────────────────────────────────────────────── -->
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <!-- ── Main content ────────────────────────────────────────────────── -->
    <main class="container my-4">
        @RenderBody()
    </main>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <footer class="border-top bg-light py-3 mt-auto">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year VGC College Student Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
