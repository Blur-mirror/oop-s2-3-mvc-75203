@model VgcCollege.Web.Models.Assignment
@{ ViewData["Title"] = "Edit Assignment"; }

<h2 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Assignment</h2>
<div class="card shadow-sm" style="max-width:540px">
    <div class="card-body">
        <form asp-action="EditAssignment" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CourseId" class="form-label fw-semibold">Course</label>
                <select asp-for="CourseId" asp-items="ViewBag.CourseId" class="form-select"></select>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="MaxScore" class="form-label fw-semibold"></label>
                    <input asp-for="MaxScore" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="DueDate" class="form-label fw-semibold"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Assignments" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
