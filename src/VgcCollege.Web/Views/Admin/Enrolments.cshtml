@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{
    ViewData["Title"] = "Enrolments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-check me-2 text-warning"></i>Enrolments</h2>
    <a asp-action="CreateEnrolment" class="btn btn-dark"><i class="bi bi-plus me-1"></i>Enrol Student</a>
</div>

<!-- Course filter -->
<form method="get" class="filter-bar">
    <select name="courseId" asp-items="ViewBag.CourseId" class="form-select">
        <option value="">All Courses</option>
    </select>
    <button type="submit" class="btn btn-outline-secondary">
        <i class="bi bi-funnel me-1"></i>Filter
    </button>
</form>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Branch</th>
                    <th>Enrolled</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.StudentProfile.Name<br /><small class="text-muted">@e.StudentProfile.StudentNumber</small>
                        </td>
                        <td>@e.Course.Name</td>
                        <td>@e.Course.Branch.Name</td>
                        <td>@e.EnrolDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span
                                class="badge @(e.Status == "Active" ? "bg-success" : e.Status == "Withdrawn" ? "bg-danger" : "bg-secondary")">
                                @e.Status
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                @foreach (var st in new[] { "Active", "Withdrawn", "Completed" })
                                {
                                    if (e.Status != st)
                                    {
                                        <form asp-action="UpdateEnrolmentStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@e.Id" />
                                            <input type="hidden" name="status" value="@st" />
                                            <button class="btn btn-xs btn-outline-secondary"
                                                    style="font-size:.75rem;padding:1px 6px;">→@st</button>
                                        </form>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
