@model VgcCollege.Web.Models.StudentProfile
@{
    ViewData["Title"] = "Edit Student";
}

<h2 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Student – @Model.Name</h2>
<div class="card shadow-sm" style="max-width:560px">
    <div class="card-body">
        <form asp-action="EditStudent" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IdentityUserId" />
            <input type="hidden" asp-for="StudentNumber" />
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="StudentNumber" class="form-label fw-semibold"></label>
                <input asp-for="StudentNumber" class="form-control" readonly />
                <div class="form-text">Student number cannot be changed.</div>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold"></label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                <input asp-for="DateOfBirth" class="form-control" type="date" />
                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Students" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
