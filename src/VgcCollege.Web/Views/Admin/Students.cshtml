@model IEnumerable<VgcCollege.Web.Models.StudentProfile>
@{ ViewData["Title"] = "Students"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2 text-warning"></i>All Students</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Student No.</th><th>Name</th><th>Email</th><th>Phone</th><th>Enrolments</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td><code>@s.StudentNumber</code></td>
                    <td>@s.Name</td>
                    <td>@s.Email</td>
                    <td>@s.Phone</td>
                    <td>
                        @foreach (var e in s.Enrolments)
                        {
                            <span class="badge bg-info text-dark me-1">@e.Course.Name</span>
                        }
                    </td>
                    <td>
                        <a asp-action="StudentDetails" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                        <a asp-action="EditStudent" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
