@model IEnumerable<VgcCollege.Web.Models.Course>
@{ ViewData["Title"] = "Courses"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-book me-2 text-warning"></i>Courses</h2>
    <a asp-action="CreateCourse" class="btn btn-dark"><i class="bi bi-plus me-1"></i>New Course</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Course</th><th>Branch</th><th>Start</th><th>End</th><th>Faculty</th><th>Students</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td class="fw-semibold">@c.Name</td>
                    <td><span class="badge bg-secondary">@c.Branch.Name</span></td>
                    <td>@c.StartDate.ToString("MMM yyyy")</td>
                    <td>@c.EndDate.ToString("MMM yyyy")</td>
                    <td>@c.FacultyAssignments.Count</td>
                    <td>@c.Enrolments.Count</td>
                    <td>
                        <a asp-action="EditCourse" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                        <form asp-action="DeleteCourse" asp-route-id="@c.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Delete course and all its data?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
