@model VgcCollege.Web.Models.StudentProfile
@{ ViewData["Title"] = Model.Name; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-circle me-2 text-warning"></i>@Model.Name</h2>
    <div class="d-flex gap-2">
        <a asp-action="EditStudent" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Students" class="btn btn-outline-dark"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-4">
    <!-- Profile card -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold"><i class="bi bi-person me-2"></i>Profile</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Student No:</strong> <code>@Model.StudentNumber</code></li>
                <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
                <li class="list-group-item"><strong>Phone:</strong> @(Model.Phone ?? "—")</li>
                <li class="list-group-item"><strong>DOB:</strong> @Model.DateOfBirth.ToString("dd MMM yyyy")</li>
                <li class="list-group-item"><strong>Address:</strong> @(Model.Address ?? "—")</li>
            </ul>
        </div>
    </div>

    <!-- Enrolments -->
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold"><i class="bi bi-journal-check me-2"></i>Enrolments</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Course</th><th>Branch</th><th>Enrolled</th><th>Status</th><th>Attendance</th></tr></thead>
                    <tbody>
                    @foreach (var e in Model.Enrolments)
                    {
                        var attended = e.AttendanceRecords.Count(a => a.Present);
                        var total    = e.AttendanceRecords.Count;
                        <tr>
                            <td>@e.Course.Name</td>
                            <td>@e.Course.Branch.Name</td>
                            <td>@e.EnrolDate.ToString("dd MMM yyyy")</td>
                            <td><span class="badge @(e.Status=="Active"?"bg-success":"bg-secondary")">@e.Status</span></td>
                            <td>@attended / @total</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Assignment results -->
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold"><i class="bi bi-table me-2"></i>Assignment Results</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Assignment</th><th>Course</th><th>Score</th><th>%</th></tr></thead>
                    <tbody>
                    @foreach (var r in Model.AssignmentResults)
                    {
                        <tr>
                            <td>@r.Assignment.Title</td>
                            <td>@r.Assignment.Course.Name</td>
                            <td>@r.Score / @r.Assignment.MaxScore</td>
                            <td>@r.Percentage%</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Exam results -->
        <div class="card shadow-sm">
            <div class="card-header fw-semibold"><i class="bi bi-pencil-square me-2"></i>Exam Results</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Exam</th><th>Course</th><th>Score</th><th>Grade</th><th>Released?</th></tr></thead>
                    <tbody>
                    @foreach (var r in Model.ExamResults)
                    {
                        <tr>
                            <td>@r.Exam.Title</td>
                            <td>@r.Exam.Course.Name</td>
                            <td>@r.Score / @r.Exam.MaxScore</td>
                            <td><span class="badge bg-primary">@r.Grade</span></td>
                            <td>
                                @if (r.Exam.ResultsReleased)
                                { <span class="badge bg-success">Released</span> }
                                else
                                { <span class="badge bg-warning text-dark">Provisional</span> }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
