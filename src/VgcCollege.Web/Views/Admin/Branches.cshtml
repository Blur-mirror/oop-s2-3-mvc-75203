@model IEnumerable<VgcCollege.Web.Models.Branch>
@{
    ViewData["Title"] = "Branches";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <h2 style="font-size:20px;font-weight:700;">
        <i class="bi bi-geo-alt me-2" style="color:var(--color-accent);"></i>Branches
    </h2>
    <a asp-action="CreateBranch" class="btn btn-dark">
        <i class="bi bi-plus me-1"></i>New Branch
    </a>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
    @foreach (var b in Model)
    {
        <div class="card" style="display:flex;flex-direction:column;">
            <div class="card-body" style="flex:1;">
                <div style="font-size:15px;font-weight:600;margin-bottom:6px;">@b.Name</div>
                <div class="text-muted" style="font-size:13px;margin-bottom:10px;">
                    <i class="bi bi-pin-map me-1"></i>@b.Address
                </div>
                <span class="badge bg-info">@b.Courses.Count course(s)</span>
            </div>
            <!-- Footer sits inside card, buttons left-aligned with proper padding -->
            <div style="padding:12px 20px;border-top:1px solid var(--color-border);
                display:flex;gap:8px;">
                <a asp-action="EditBranch" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <form asp-action="DeleteBranch" asp-route-id="@b.Id" method="post"
                      onsubmit="return confirm('Delete this branch?')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    }
</div>
