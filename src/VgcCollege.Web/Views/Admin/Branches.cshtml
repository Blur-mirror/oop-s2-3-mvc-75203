@model IEnumerable<VgcCollege.Web.Models.Branch>
@{ ViewData["Title"] = "Branches"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-geo-alt me-2 text-warning"></i>Branches</h2>
    <a asp-action="CreateBranch" class="btn btn-dark"><i class="bi bi-plus me-1"></i>New Branch</a>
</div>

<div class="row g-3">
@foreach (var b in Model)
{
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">@b.Name</h5>
                <p class="card-text text-muted small"><i class="bi bi-pin-map me-1"></i>@b.Address</p>
                <span class="badge bg-info">@b.Courses.Count course(s)</span>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2">
                <a asp-action="EditBranch" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <form asp-action="DeleteBranch" asp-route-id="@b.Id" method="post"
                      onsubmit="return confirm('Delete this branch?')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                </form>
            </div>
        </div>
    </div>
}
</div>
