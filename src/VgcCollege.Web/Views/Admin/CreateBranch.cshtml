@model VgcCollege.Web.Models.Branch
@{ ViewData["Title"] = "New Branch"; }

<h2 class="mb-4"><i class="bi bi-geo-alt me-2"></i>New Branch</h2>
<div class="card shadow-sm" style="max-width:540px">
    <div class="card-body">
        <form asp-action="CreateBranch" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold"></label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Branches" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
