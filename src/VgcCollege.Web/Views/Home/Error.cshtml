@model VgcCollege.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3rem;"></i>
    <h1 class="display-5 mt-3">Something went wrong</h1>
    <p class="text-muted">An unexpected error occurred. Please try again or contact support.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark">Go Home</a>
</div>
